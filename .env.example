# Supabase (frontend — anon key is public-safe; RLS protects the data)
# Local dev: copy this file to `.env.local` and fill in real values.
# Production: set these as environment variables on Vercel/Render.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: Google Sheet webhook for lead forwarding
SHEET_WEBHOOK_URL=
